---
const features = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>`,
    title: 'Live Style Sync',
    description: 'MutationObserver keeps styles, themes, and CSS-in-JS changes synced in real time.',
    color: 'var(--color-accent)',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M8.25 7.5V6.108c0-1.135.845-2.098 1.976-2.192.373-.03.748-.057 1.123-.08M15.75 18H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08M15.75 18.75v-1.875a3.375 3.375 0 00-3.375-3.375h-1.5a1.125 1.125 0 01-1.125-1.125v-1.5A3.375 3.375 0 006.375 7.5H5.25m11.9-3.664A2.251 2.251 0 0015 2.25h-1.5a2.251 2.251 0 00-2.15 1.586m5.8 0c.065.21.1.433.1.664v.75h-6V4.5c0-.231.035-.454.1-.664M6.75 7.5H4.875c-.621 0-1.125.504-1.125 1.125v12c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V16.5a9 9 0 00-9-9z"/></svg>`,
    title: 'Controlled & Uncontrolled',
    description: 'Works both ways — industry-standard API with `open` prop for full state control.',
    color: 'var(--color-cyan)',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"/></svg>`,
    title: 'Move / Clone / Portal',
    description: 'Three DOM strategies. Move preserves state, portal keeps component tree intact.',
    color: 'var(--color-emerald)',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/></svg>`,
    title: 'Auto-sizing & Responsive',
    description: 'Windows adapt to content size automatically. Use `isInsidePip` for responsive PiP layouts.',
    color: 'var(--color-amber)',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z"/></svg>`,
    title: 'Keyboard Forwarding',
    description: 'Cmd+S, Cmd+K, and all shortcuts keep working inside the PiP window.',
    color: 'var(--color-rose)',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/></svg>`,
    title: 'Graceful Fallbacks',
    description: 'Firefox & Safari fallback to new tab, or your custom handler (e.g. a modal).',
    color: 'var(--color-amber)',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z"/></svg>`,
    title: 'SSR-Safe',
    description: 'Works in Next.js, Remix, and Vite out of the box. No hydration mismatches.',
    color: 'var(--color-cyan)',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.86-2.54a4.5 4.5 0 00-1.242-7.244l-4.5-4.5a4.5 4.5 0 00-6.364 6.364L4.34 8.586" transform="translate(2, 2) scale(0.83)"/></svg>`,
    title: 'Decoupled Triggers',
    description: 'Named registry lets any trigger connect to any wrapper — no shared context needed.',
    color: 'var(--color-emerald)',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>`,
    title: 'TypeScript-First',
    description: 'Generic-typed hooks, full IntelliSense, zero type casting needed.',
    color: 'var(--color-accent)',
  },
];
---

<section id="features" class="relative py-24 px-4 sm:px-6">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16" data-reveal>
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">
        Everything you need for
        <span class="gradient-text">Picture-in-Picture</span>
      </h2>
      <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">
        A comprehensive API designed for real-world use cases — from simple pop-outs to complex editor workflows.
      </p>
    </div>

    <!-- Feature grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5" data-reveal-stagger>
      {features.map((feature) => (
        <div class="glass-card p-6 transition-all duration-300 hover:translate-y-[-2px] group">
          <div
            class="w-10 h-10 rounded-xl flex items-center justify-center mb-4 transition-transform duration-300 group-hover:scale-110"
            style={`background: linear-gradient(135deg, ${feature.color}20, ${feature.color}10); color: ${feature.color};`}
          >
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">{feature.title}</h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
