---
// Hero section — logo-less, tagline + install + CTAs
---

<section id="hero" class="relative min-h-screen flex flex-col items-center justify-center px-4 pt-20 pb-16 overflow-hidden">
  <!-- Background orbs -->
  <div class="gradient-orb w-[500px] h-[500px] bg-[#7c5cff] top-[-10%] left-[-10%]"></div>
  <div class="gradient-orb w-[400px] h-[400px] bg-[#22d3ee] bottom-[-5%] right-[-5%] opacity-20"></div>

  <div class="relative z-10 max-w-4xl mx-auto text-center">
    <!-- Badge -->
    <div class="animate-fade-in inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[var(--color-border)] bg-[var(--color-bg-card)] text-sm text-[var(--color-text-muted)] mb-8">
      <span class="w-2 h-2 rounded-full bg-[var(--color-emerald)] animate-pulse"></span>
      Active Beta · v0.1.9
    </div>

    <!-- Title -->
    <h1 class="animate-fade-in-up text-5xl sm:text-6xl md:text-7xl font-extrabold tracking-tight leading-[1.1] mb-6">
      <span class="gradient-text">pip-it-up</span> <br />
      <span class="text-4xl sm:text-5xl md:text-6xl opacity-90">Picture-in-Picture</span>
    </h1>

    <!-- Tagline -->
    <p class="animate-fade-in-up text-xl sm:text-2xl text-[var(--color-text-muted)] max-w-2xl mx-auto mb-10 leading-relaxed" style="animation-delay: 0.1s">
      Pop any UI component into a floating
      <span class="text-[var(--color-text)]">Picture-in-Picture</span> window.
      <br class="hidden sm:block" />
      Zero config. Auto-sizing. Framework-agnostic core.
    </p>

    <!-- Install command -->
    <div class="animate-fade-in-up flex justify-center mb-10" style="animation-delay: 0.2s">
      <div id="install-command" class="group relative inline-flex items-center gap-3 px-6 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-code)] font-mono text-sm sm:text-base cursor-pointer hover:border-[var(--color-accent)] transition-colors duration-300">
        <span class="text-[var(--color-text-dim)]">$</span>
        <span class="text-[var(--color-text)]">npm i @pip-it-up/react</span>
        <button
          id="copy-install-btn"
          class="ml-2 p-1.5 rounded-lg hover:bg-[var(--color-bg-elevated)] transition-colors"
          aria-label="Copy install command"
        >
          <svg class="w-4 h-4 text-[var(--color-text-muted)] group-hover:text-[var(--color-accent-light)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path>
          </svg>
        </button>
        <!-- Copied tooltip -->
        <span id="copy-tooltip" class="absolute -top-10 left-1/2 -translate-x-1/2 px-3 py-1 rounded-lg bg-[var(--color-accent)] text-white text-xs font-medium opacity-0 pointer-events-none transition-opacity duration-200">
          Copied!
        </span>
      </div>
    </div>

    <!-- CTAs -->
    <div class="animate-fade-in-up flex flex-col sm:flex-row items-center justify-center gap-4" style="animation-delay: 0.3s">
      <a
        href="#code-snippets"
        id="cta-get-started"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-[var(--color-accent)] text-white font-semibold text-base hover:bg-[var(--color-accent-dark)] transition-all duration-300 animate-pulse-glow"
      >
        Get Started
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path d="M19 9l-7 7-7-7"></path>
        </svg>
      </a>
      <a
        href="https://github.com/Shakya47/pip-it-up"
        target="_blank"
        rel="noopener noreferrer"
        id="cta-github"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl border border-[var(--color-border)] text-[var(--color-text)] font-semibold text-base hover:border-[var(--color-text-dim)] hover:bg-[var(--color-bg-card)] transition-all duration-300"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        View on GitHub
      </a>
    </div>
  </div>

  <!-- Copy script -->
  <script>
    const btn = document.getElementById('copy-install-btn');
    const cmd = document.getElementById('install-command');
    const tooltip = document.getElementById('copy-tooltip');

    function copyCommand() {
      navigator.clipboard.writeText('npm i @pip-it-up/react');
      if (tooltip) {
        tooltip.style.opacity = '1';
        setTimeout(() => { tooltip.style.opacity = '0'; }, 1500);
      }
    }

    btn?.addEventListener('click', (e) => {
      e.stopPropagation();
      copyCommand();
    });
    cmd?.addEventListener('click', copyCommand);
  </script>
</section>
