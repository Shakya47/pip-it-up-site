---
const roadmapItems = [
  {
    title: 'Seamless Video & Canvas PiP',
    description: 'DOM node identity preserved across open/close. Keep WebRTC streams, canvas animations, and video playheads perfectly running without restarts.',
    status: 'Active Development',
    statusColor: 'var(--color-accent)',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.375 19.5h17.25m-17.25 0a1.125 1.125 0 01-1.125-1.125M3.375 19.5h7.5c.621 0 1.125-.504 1.125-1.125m-9.75 0V5.625m0 12.75v-1.5c0-.621.504-1.125 1.125-1.125m18.375 2.625V5.625m0 12.75c0 .621-.504 1.125-1.125 1.125m-1.5-1.5a1.125 1.125 0 01-1.125-1.125M18 19.5h-7.5M18 19.5v-1.5a1.125 1.125 0 00-1.125-1.125m-13.5-3.75h15.75m-15.75-3.75h15.75m-15.75-3.75h15.75m-.75-3h-14.25a1.125 1.125 0 00-1.125 1.125v12.75c0 .621.504 1.125 1.125 1.125h14.25a1.125 1.125 0 001.125-1.125V3.375a1.125 1.125 0 00-1.125-1.125z"/></svg>`,
    active: true
  },
  {
    title: 'Vue & Svelte Bindings',
    description: 'Provide native `@pip-it-up/vue` and `@pip-it-up/svelte` bindings with standard ref controllers, hooks, and slots for full ecosystem support.',
    status: 'Planned',
    statusColor: '#64748b',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M14.25 9.75L16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z"/></svg>`,
    active: false
  },
  {
    title: 'Angular Bindings',
    description: 'Provide native `@pip-it-up/angular` directive and service architecture for complete support across enterprise Angular applications.',
    status: 'Planned',
    statusColor: '#64748b',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>`,
    active: false
  },
  {
    title: 'v1.0 Stable Release',
    description: 'API freeze, full browser matrix automated integration testing, accessibility compliance audits, and production-grade optimization.',
    status: 'Planned',
    statusColor: '#64748b',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/></svg>`,
    active: false
  }
];
---

<section id="roadmap" class="relative py-24 px-4 sm:px-6 overflow-hidden">
  <!-- Glowing subtle gradient in background -->
  <div class="absolute w-[300px] h-[300px] bg-[#7c5cff]/5 blur-[120px] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 rounded-full pointer-events-none"></div>

  <div class="max-w-4xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16" data-reveal>
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[var(--color-border)] bg-[var(--color-bg-card)] text-xs font-semibold text-[var(--color-accent-light)] mb-4 tracking-wider uppercase">
        Roadmap
      </div>
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">
        What's <span class="gradient-text">coming next</span>
      </h2>
      <p class="text-lg text-[var(--color-text-muted)] max-w-xl mx-auto">
        We are actively iterating towards our stable v1.0 release. Here is what we are building.
      </p>
    </div>

    <!-- Roadmap Rows Stack -->
    <div class="flex flex-col gap-4" data-reveal-stagger>
      {roadmapItems.map((item) => (
        <div class="glass-card p-5 sm:p-6 flex flex-col md:flex-row md:items-center justify-between gap-6 relative group hover:border-[var(--color-border-subtle)] transition-all duration-300">
          <div class="flex items-start gap-4 flex-1">
            <!-- Icon -->
            <div 
              class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" 
              style={`background: linear-gradient(135deg, ${item.statusColor}20, ${item.statusColor}10); color: ${item.statusColor};`}
            >
              <Fragment set:html={item.icon} />
            </div>
            <!-- Title & Description -->
            <div>
              <h3 class="text-lg font-semibold text-white mb-1">{item.title}</h3>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
                {item.description}
              </p>
            </div>
          </div>

          <!-- Status badge -->
          <div class="flex-shrink-0 self-start md:self-center">
            <span 
              class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold border"
              style={`border-color: ${item.statusColor}30; background: ${item.statusColor}08; color: ${item.statusColor};`}
            >
              {item.active && <span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse"></span>}
              {item.status}
            </span>
          </div>
        </div>
      ))}
    </div>

    <!-- Issue Callout -->
    <div class="mt-12 text-center" data-reveal>
      <p class="text-sm text-[var(--color-text-muted)]">
        Have a feature request or want to contribute? 
        <a 
          href="https://github.com/Shakya47/pip-it-up/issues" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="text-white hover:text-[var(--color-accent-light)] underline decoration-[var(--color-accent-light)]/40 hover:decoration-[var(--color-accent-light)] transition-colors ml-1 font-semibold"
        >
          Open an issue on GitHub &rarr;
        </a>
      </p>
    </div>
  </div>
</section>
